{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/webhook", "dest": "app.py" },
    { "src": "/upload", "dest": "app.py" },
    { "src": "/upload.html", "dest": "app.py" },
    { "src": "/list", "dest": "app.py" },
    { "src": "/files/(.*)", "dest": "app.py" },
    { "src": "/test", "dest": "app.py" },
    { "src": "/", "dest": "app.py" }
  ]
}
